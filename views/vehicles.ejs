<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Vehicle Inventory</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('partials/nav') %>

  <main class="container">

    <section class="hero">
      <div>
        <p class="eyebrow">Car Dealership Inventory</p>
        <h1>Find your next vehicle</h1>
        <p class="hero-text">
          Browse our inventory, view vehicle details, leave reviews, and request service in one place.
        </p>
      </div>
      <div class="hero-actions">
        <a class="btn" href="#inventory">View Inventory</a>
        <a class="btn secondary" href="/contact">Contact Us</a>
      </div>
    </section>

    <section class="stats">
      <div class="stat-card">
        <strong><%= vehicles.length %></strong>
        <span>Vehicles<%= selectedCategory ? ' in ' + selectedCategory.name : ' in Inventory' %></span>
      </div>
      <div class="stat-card">
        <strong>3</strong>
        <span>User Roles</span>
      </div>
      <div class="stat-card">
        <strong>24/7</strong>
        <span>Online Access</span>
      </div>
    </section>

    <section id="inventory">
      <h2 class="section-title">Browse by Category</h2>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;">
        <a class="btn <%= !selectedCategory ? '' : 'secondary' %>" href="/vehicles">All Vehicles</a>
        <% categories.forEach(cat => { %>
          <a class="btn <%= selectedCategory && selectedCategory.id === cat.id ? '' : 'secondary' %>"
             href="/vehicles?category=<%= cat.id %>">
            <%= cat.name %>
          </a>
        <% }) %>
      </div>

      <% if (selectedCategory) { %>
        <p class="small-muted" style="margin-bottom:16px;">
          Showing <strong><%= vehicles.length %></strong> vehicle<%= vehicles.length !== 1 ? 's' : '' %> in <strong><%= selectedCategory.name %></strong>
        </p>
      <% } %>

      <% if (vehicles.length > 0) { %>
        <div class="vehicle-grid">
          <% vehicles.forEach(vehicle => { %>
            <article class="card vehicle-card">
              <div class="vehicle-card-header">
                <h3><%= vehicle.title %></h3>
                <% if (vehicle.available) { %>
                  <span class="badge badge-available">Available</span>
                <% } else { %>
                  <span class="badge badge-unavailable">Unavailable</span>
                <% } %>
              </div>
              <p class="price">$<%= Number(vehicle.price).toFixed(2) %></p>
              <p class="small-muted">
                <%= vehicle.description || "No description available." %>
              </p>
              <div class="card-actions">
                <a class="btn" href="/vehicles/<%= vehicle.id %>">View Details</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p>No vehicles found<%= selectedCategory ? ' in this category' : '' %>.</p>
      <% } %>
    </section>

  </main>
</body>
</html>