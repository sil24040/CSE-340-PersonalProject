<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>My Profile</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('partials/nav') %>

  <main class="container">
    <div class="hero" style="display:block;">
      <p class="eyebrow">Account</p>
      <h1>My Profile</h1>
      <p class="hero-text">Manage your account details and view your service history.</p>
    </div>

    <% if (error) { %>
      <div class="notice error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="notice success"><%= success %></div>
    <% } %>

    <div class="card">
      <h2 class="section-title">Account Details</h2>
      <form method="POST" action="/profile">
        <label>Name</label>
        <input name="name" value="<%= user.name %>" placeholder="Name" required>

        <label>Email</label>
        <input name="email" type="email" value="<%= user.email %>" placeholder="Email" required>

        <hr>
        <p class="small-muted">Leave new password blank to keep your current password.</p>

        <label>Current Password</label>
        <input type="password" name="currentPassword" placeholder="Current password" required>

        <label>New Password</label>
        <input type="password" name="newPassword" placeholder="New password (optional)">

        <button type="submit">Update Profile</button>
      </form>
    </div>

    <h2 class="section-title" style="margin-top:28px;">My Service Requests</h2>

    <% if (serviceRequests && serviceRequests.length > 0) { %>
      <% serviceRequests.forEach(r => { %>
        <div class="card">
          <div style="display:flex;justify-content:space-between;align-items:start;gap:10px;flex-wrap:wrap;">
            <div>
              <p style="margin:0 0 4px;"><strong><%= r.title %></strong></p>
              <p class="small-muted" style="margin:0 0 8px;">
                Submitted <%= new Date(r.created_at).toLocaleDateString() %>
              </p>
              <p style="margin:0 0 6px;"><%= r.description %></p>
              <% if (r.notes) { %>
                <p class="small-muted" style="margin:0;"><strong>Notes:</strong> <%= r.notes %></p>
              <% } %>
            </div>
            <span class="badge"
              style="<%= r.status === 'Completed' ? 'background:#dcfce7;color:#166534;' : r.status === 'In Progress' ? 'background:#fef3c7;color:#92400e;' : 'background:#eff6ff;color:#1d4ed8;' %>">
              <%= r.status %>
            </span>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="card">
        <p class="small-muted">You haven't submitted any service requests yet.</p>
      </div>
    <% } %>

    <h2 class="section-title" style="margin-top:28px;">My Reviews</h2>

    <% if (reviews && reviews.length > 0) { %>
      <% reviews.forEach(r => { %>
        <div class="card">
          <div style="display:flex;justify-content:space-between;align-items:start;gap:10px;flex-wrap:wrap;">
            <div>
              <p style="margin:0 0 4px;"><strong><a href="/vehicles/<%= r.vehicle_id %>"><%= r.vehicle_title %></a></strong></p>
              <p class="small-muted" style="margin:0 0 8px;">Rating: <%= r.rating %>/5 &bull; <%= new Date(r.created_at).toLocaleDateString() %></p>
              <p style="margin:0;"><%= r.comment %></p>
            </div>
            <div style="display:flex;gap:8px;flex-shrink:0;">
              <a class="btn secondary" href="/reviews/<%= r.id %>/edit" style="padding:8px 12px;font-size:0.85rem;">Edit</a>
              <form method="POST" action="/reviews/<%= r.id %>/delete" onsubmit="return confirm('Delete this review?');">
                <button type="submit" style="background:#ef4444;padding:8px 12px;font-size:0.85rem;">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="card">
        <p class="small-muted">You haven't written any reviews yet.</p>
      </div>
    <% } %>

  </main>
</body>
</html>