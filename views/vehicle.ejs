<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title><%= vehicle.title %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav class="nav">
    <a href="/vehicles">Home</a>
    <a href="/profile">Profile</a>
    <a href="/employee">Employee Dashboard</a>
    <a href="/owner">Owner Dashboard</a>
    <a href="/contact">Contact</a>

    <% if (currentUser) { %>
      <span class="small-muted">Logged in as <strong><%= currentUser.name %></strong></span>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>

  <main class="container">

    <div class="hero">
      <div>
        <p class="eyebrow">Vehicle Details</p>
        <h1><%= vehicle.title %></h1>
        <p class="hero-text"><strong>Price:</strong> $<%= vehicle.price %></p>
      </div>
    </div>

    <div class="card">
      <h2 class="section-title">Description</h2>
      <p><%= vehicle.description %></p>
    </div>

    <h2 class="section-title">Reviews</h2>

    <% if (reviews && reviews.length > 0) { %>
      <% reviews.forEach(review => { %>
        <div class="card">
          <p><strong><%= review.name %></strong></p>
          <p>Rating: <%= review.rating %> / 5</p>
          <p><%= review.comment %></p>
        </div>
      <% }) %>
    <% } else { %>
      <p>No reviews yet.</p>
    <% } %>

    <% if (currentUser) { %>
      <div class="card">
        <h3>Leave Review</h3>
        <form method="POST" action="/vehicles/<%= vehicle.id %>/reviews">
          <label>Rating</label>
          <select name="rating" required>
            <option value="5">5</option>
            <option value="4">4</option>
            <option value="3">3</option>
            <option value="2">2</option>
            <option value="1">1</option>
          </select>

          <label>Comment</label>
          <textarea name="comment" required></textarea>

          <button type="submit">Submit Review</button>
        </form>
      </div>

      <div class="card">
        <h3>Request Service</h3>
        <form method="POST" action="/vehicles/<%= vehicle.id %>/request">
          <label>Description</label>
          <textarea name="description" required></textarea>
          <button type="submit">Submit Request</button>
        </form>
      </div>
    <% } else { %>
      <div class="card">
        <p><a href="/login">Login</a> to leave a review or request service.</p>
      </div>
    <% } %>

  </main>
</body>
</html>