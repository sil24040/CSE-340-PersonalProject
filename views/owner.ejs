<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Owner Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('partials/nav') %>

  <main class="container">
    <div class="hero">
      <div>
        <p class="eyebrow">Owner tools</p>
        <h1>Owner Dashboard</h1>
        <p class="hero-text">Manage users, categories, vehicles, and review service requests.</p>
      </div>
    </div>

    <h2 class="section-title">Users</h2>
    <div class="table-wrap">
      <table>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Change Role</th>
          <th>Delete</th>
        </tr>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.role %></td>
            <td>
              <form method="POST" action="/owner/users/<%= user.id %>/role">
                <select name="role">
                  <option value="user" <%= user.role === "user" ? "selected" : "" %>>user</option>
                  <option value="employee" <%= user.role === "employee" ? "selected" : "" %>>employee</option>
                  <option value="owner" <%= user.role === "owner" ? "selected" : "" %>>owner</option>
                </select>
                <button type="submit">Update</button>
              </form>
            </td>
            <td>
              <% if (user.id !== currentUser.id) { %>
                <form method="POST" action="/owner/users/<%= user.id %>/delete"
                      onsubmit="return confirm('Delete this user? This cannot be undone.');">
                  <button type="submit" style="background:#ef4444;">Delete</button>
                </form>
              <% } else { %>
                <span class="small-muted">You</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>

    <h2 class="section-title" style="margin-top:28px;">Categories</h2>

    <div class="card">
      <form method="POST" action="/owner/categories">
        <label>New Category</label>
        <input name="name" placeholder="Category name" required>
        <button type="submit">Add Category</button>
      </form>
    </div>

    <% categories.forEach(category => { %>
      <div class="card">
        <form method="POST" action="/owner/categories/<%= category.id %>/edit" style="margin-bottom:10px;">
          <label>Edit: <strong><%= category.name %></strong></label>
          <input name="name" value="<%= category.name %>" required>
          <button type="submit">Save</button>
        </form>
        <form method="POST" action="/owner/categories/<%= category.id %>/delete"
              onsubmit="return confirm('Delete this category?');">
          <button type="submit" style="background:#ef4444;">Delete Category</button>
        </form>
      </div>
    <% }) %>

    <h2 class="section-title" style="margin-top:28px;">Vehicles</h2>

    <div class="card">
      <h3>Add New Vehicle</h3>
      <form method="POST" action="/owner/vehicles">
        <label>Title</label>
        <input name="title" placeholder="Vehicle title" required>

        <label>Description</label>
        <textarea name="description" placeholder="Description"></textarea>

        <label>Price</label>
        <input name="price" type="number" step="0.01" placeholder="Price" required>

        <label>Category</label>
        <select name="category_id">
          <option value="">-- No Category --</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>

        <label>Status</label>
        <select name="available">
          <option value="true">Available</option>
          <option value="false">Not Available</option>
        </select>

        <button type="submit">Add Vehicle</button>
      </form>
    </div>

    <% vehicles.forEach(vehicle => { %>
      <div class="card">
        <form method="POST" action="/owner/vehicles/<%= vehicle.id %>/edit" style="margin-bottom:10px;">
          <p style="margin:0 0 10px;font-weight:700;">Edit: <%= vehicle.title %></p>

          <label>Title</label>
          <input name="title" value="<%= vehicle.title %>" required>

          <label>Description</label>
          <textarea name="description"><%= vehicle.description || '' %></textarea>

          <label>Price</label>
          <input name="price" type="number" step="0.01" value="<%= vehicle.price %>" required>

          <label>Category</label>
          <select name="category_id">
            <option value="">-- No Category --</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= vehicle.category_id == cat.id ? "selected" : "" %>>
                <%= cat.name %>
              </option>
            <% }) %>
          </select>

          <label>Status</label>
          <select name="available">
            <option value="true" <%= vehicle.available ? "selected" : "" %>>Available</option>
            <option value="false" <%= !vehicle.available ? "selected" : "" %>>Not Available</option>
          </select>

          <button type="submit">Save</button>
        </form>

        <hr>
        <p style="font-weight:700;margin-bottom:8px;">Images</p>

        <% if (vehicle.images && vehicle.images.length > 0) { %>
          <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:12px;">
            <% vehicle.images.forEach(img => { %>
              <div>
                <img src="<%= img.image_url %>" alt="vehicle"
                     style="width:120px;height:80px;object-fit:cover;border-radius:8px;border:1px solid var(--border);">
                <form method="POST" action="/owner/images/<%= img.id %>/delete"
                      onsubmit="return confirm('Delete this image?');"
                      style="margin:4px 0 0 0;">
                  <button type="submit" style="background:#ef4444;padding:4px 8px;font-size:0.75rem;width:100%;">Remove</button>
                </form>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="small-muted" style="margin-bottom:8px;">No images yet.</p>
        <% } %>

        <form method="POST" action="/owner/vehicles/<%= vehicle.id %>/images" style="margin-bottom:10px;">
          <label>Add Image URL</label>
          <input name="image_url" placeholder="https://example.com/image.jpg" type="url">
          <button type="submit">Add Image</button>
        </form>

        <form method="POST" action="/owner/vehicles/<%= vehicle.id %>/delete"
              onsubmit="return confirm('Delete this vehicle?');">
          <button type="submit" style="background:#ef4444;">Delete Vehicle</button>
        </form>
      </div>
    <% }) %>

    <h2 class="section-title" style="margin-top:28px;">Recent Service Requests</h2>

    <% if (requests && requests.length > 0) { %>
      <% requests.forEach(r => { %>
        <div class="card">
          <p><strong>User:</strong> <%= r.name %></p>
          <p><strong>Vehicle:</strong> <%= r.title %></p>
          <p><strong>Status:</strong> <%= r.status %></p>
          <p><strong>Description:</strong> <%= r.description %></p>
          <% if (r.notes) { %>
            <p><strong>Notes:</strong> <%= r.notes %></p>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="small-muted">No service requests yet.</p>
    <% } %>

  </main>
</body>
</html>