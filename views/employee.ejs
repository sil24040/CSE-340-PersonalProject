<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Employee Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('partials/nav') %>

  <main class="container">
    <div class="hero">
      <div>
        <p class="eyebrow">Employee tools</p>
        <h1>Employee Dashboard</h1>
        <p class="hero-text">Manage service requests, vehicles, reviews, and contact messages.</p>
      </div>
    </div>

    <h2 class="section-title">Service Requests</h2>

    <% if (requests && requests.length > 0) { %>
      <% requests.forEach(r => { %>
        <div class="card">
          <p><strong>User:</strong> <%= r.name %></p>
          <p><strong>Vehicle:</strong> <%= r.title %></p>
          <p><strong>Description:</strong> <%= r.description %></p>
          <% if (r.notes) { %>
            <p><strong>Notes:</strong> <%= r.notes %></p>
          <% } %>
          <p>
            <strong>Status:</strong>
            <span class="badge"
              style="<%= r.status === 'Completed' ? 'background:#dcfce7;color:#166534;' : r.status === 'In Progress' ? 'background:#fef3c7;color:#92400e;' : 'background:#eff6ff;color:#1d4ed8;' %>">
              <%= r.status %>
            </span>
          </p>
          <p class="small-muted">Submitted: <%= new Date(r.created_at).toLocaleDateString() %></p>

          <form method="POST" action="/requests/<%= r.id %>/status" style="margin-bottom:10px;">
            <label>Update Status</label>
            <select name="status" required>
              <option value="Submitted" <%= r.status === "Submitted" ? "selected" : "" %>>Submitted</option>
              <option value="In Progress" <%= r.status === "In Progress" ? "selected" : "" %>>In Progress</option>
              <option value="Completed" <%= r.status === "Completed" ? "selected" : "" %>>Completed</option>
            </select>
            <button type="submit">Update Status</button>
          </form>

          <form method="POST" action="/requests/<%= r.id %>/notes">
            <label>Add / Update Notes</label>
            <textarea name="notes" placeholder="Add notes for this request..."><%= r.notes || '' %></textarea>
            <button type="submit">Save Notes</button>
          </form>
        </div>
      <% }) %>
    <% } else { %>
      <p>No service requests yet.</p>
    <% } %>

    <h2 class="section-title" style="margin-top:28px;">Vehicles</h2>
    <p class="small-muted">Edit vehicle details like price, description, and availability.</p>

    <% if (vehicles && vehicles.length > 0) { %>
      <% vehicles.forEach(vehicle => { %>
        <div class="card">
          <form method="POST" action="/employee/vehicles/<%= vehicle.id %>/edit">
            <p style="margin:0 0 12px;font-weight:700;font-size:1.05rem;"><%= vehicle.title %></p>

            <label>Description</label>
            <textarea name="description"><%= vehicle.description || '' %></textarea>

            <label>Price</label>
            <input name="price" type="number" step="0.01" value="<%= vehicle.price %>" required>

            <label>Status</label>
            <select name="available">
              <option value="true" <%= vehicle.available ? "selected" : "" %>>Available</option>
              <option value="false" <%= !vehicle.available ? "selected" : "" %>>Not Available</option>
            </select>

            <button type="submit">Save Changes</button>
          </form>
        </div>
      <% }) %>
    <% } else { %>
      <p>No vehicles in inventory.</p>
    <% } %>

    <h2 class="section-title" style="margin-top:28px;">All Reviews</h2>
    <p class="small-muted">Remove inappropriate reviews.</p>

    <% if (reviews && reviews.length > 0) { %>
      <% reviews.forEach(review => { %>
        <div class="card">
          <p><strong><%= review.reviewer_name %></strong> on <a href="/vehicles/<%= review.vehicle_id %>"><%= review.vehicle_title %></a></p>
          <p>Rating: <%= review.rating %>/5</p>
          <p><%= review.comment %></p>
          <p class="small-muted"><%= new Date(review.created_at).toLocaleDateString() %></p>
          <form method="POST" action="/reviews/<%= review.id %>/delete"
                onsubmit="return confirm('Remove this review?');">
            <button type="submit" style="background:#ef4444;">Remove Review</button>
          </form>
        </div>
      <% }) %>
    <% } else { %>
      <p>No reviews yet.</p>
    <% } %>

    <h2 class="section-title" style="margin-top:28px;">Contact Messages</h2>

    <% if (contactMessages && contactMessages.length > 0) { %>
      <% contactMessages.forEach(msg => { %>
        <div class="card">
          <p><strong><%= msg.name %></strong> &lt;<%= msg.email %>&gt;</p>
          <p class="small-muted"><%= new Date(msg.created_at).toLocaleDateString() %></p>
          <p><%= msg.message %></p>
        </div>
      <% }) %>
    <% } else { %>
      <p>No contact messages yet.</p>
    <% } %>

  </main>
</body>
</html>