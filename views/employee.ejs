<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Employee Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav class="nav">
    <a href="/vehicles">Home</a>
    <a href="/profile">Profile</a>
    <a href="/employee">Employee Dashboard</a>
    <a href="/owner">Owner Dashboard</a>
    <a href="/contact">Contact</a>

    <% if (currentUser) { %>
      <span class="small-muted">Logged in as <strong><%= currentUser.name %></strong></span>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>

  <main class="container">
    <div class="hero">
      <div>
        <p class="eyebrow">Employee tools</p>
        <h1>Service Requests</h1>
        <p class="hero-text">Review service requests and update their status.</p>
      </div>
    </div>

    <% if (requests && requests.length > 0) { %>
      <% requests.forEach(r => { %>
        <div class="card">
          <p><strong>User:</strong> <%= r.name %></p>
          <p><strong>Vehicle:</strong> <%= r.title %></p>
          <p><strong>Description:</strong> <%= r.description %></p>
          <p><strong>Status:</strong> <%= r.status %></p>

          <form method="POST" action="/requests/<%= r.id %>/status">
            <label>Update Status</label>
            <select name="status" required>
              <option value="Submitted" <%= r.status === "Submitted" ? "selected" : "" %>>Submitted</option>
              <option value="In Progress" <%= r.status === "In Progress" ? "selected" : "" %>>In Progress</option>
              <option value="Completed" <%= r.status === "Completed" ? "selected" : "" %>>Completed</option>
            </select>
            <button type="submit">Update</button>
          </form>
        </div>
      <% }) %>
    <% } else { %>
      <p>No service requests yet.</p>
    <% } %>
  </main>
</body>
</html>